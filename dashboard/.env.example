# --- Required ---------------------------------------------------------

# Postgres URL — same DB the bot uses (panda schema is shared).
DATABASE_URL=postgresql://user:pass@host:5432/dbname

# Random 32+ byte secret used to sign session cookies. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# --- Echoed OAuth2 ---------------------------------------------------
# Register an app at https://echoed.gg/settings/oauth2 (or wherever
# the user-facing OAuth2 settings live) with scopes: openid profile
# email servers. Set the redirect URI to <DASHBOARD_BASE_URL>/auth/callback.
ECHOED_OAUTH_CLIENT_ID=
ECHOED_OAUTH_CLIENT_SECRET=
ECHOED_OAUTH_BASE=https://go.echoed.gg

# --- Public dashboard URL --------------------------------------------
# Used to construct the OAuth redirect_uri. No trailing slash.
DASHBOARD_BASE_URL=http://localhost:3030
